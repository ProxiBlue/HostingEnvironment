check process php-fpm with pidfile /var/run/php-fpm.pid
    start program = "/usr/bin/systemctl start php-fpm"
    stop program = "/usr/bin/systemctl stop php-fpm"
    if failed unixsocket /var/run/php-fpm.socket then restart
    if 5 restarts within 5 cycles then alert
    if totalmem > 3 GB for 5 cycles then restart
